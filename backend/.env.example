# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sms_dev?schema=public"

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Frontend origin allowed for CORS
CLIENT_ORIGIN="http://localhost:5173"

# Email (password reset). Leave RESEND_API_KEY unset to keep the dev stub
# (logs the reset link to the console instead of sending a real email).
RESEND_API_KEY=""
FROM_EMAIL="onboarding@resend.dev"
